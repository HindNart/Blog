<div class="page-container post-detail-page">
    <div class="post-detail-layout">

        <!-- Bài viết chính -->
        <article class="post-detail" id="postArticle">
            <header class="post-detail-header">
                {{#if post.category}}
                <a href="/posts?category={{post.category.slug}}" class="post-category-badge">{{post.category.name}}</a>
                {{/if}}
                <h1 class="post-detail-title">{{post.title}}</h1>
                <div class="post-detail-meta">
                    <span class="meta-item">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2">
                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                            <circle cx="12" cy="7" r="4" />
                        </svg>
                        {{post.author.username}}
                    </span>
                    <span class="meta-item">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2">
                            <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                            <line x1="16" y1="2" x2="16" y2="6" />
                            <line x1="8" y1="2" x2="8" y2="6" />
                            <line x1="3" y1="10" x2="21" y2="10" />
                        </svg>
                        {{formatDate post.createdAt}}
                    </span>
                    <span class="meta-item">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                            <circle cx="12" cy="12" r="3" />
                        </svg>
                        {{post.views}} lượt xem
                    </span>
                </div>

                {{#if isOwner}}
                <div class="post-owner-actions">
                    {{#if (eq post.status 'approved')}}
                    <a href="/posts/{{post._id}}/edit" class="btn btn-secondary btn-sm-resp">✏️ Chỉnh sửa</a>
                    <form action="/posts/{{post._id}}/delete?_method=DELETE" method="POST" style="display:inline">
                        <button type="submit" class="btn btn-danger btn-sm-resp"
                            onclick="return confirm('Bạn có chắc muốn xóa bài này?')">🗑️ Xóa</button>
                    </form>
                    {{/if}}
                    {{#if (eq post.status 'rejected')}}
                    <div class="rejection-notice">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2">
                            <circle cx="12" cy="12" r="10" />
                            <line x1="15" y1="9" x2="9" y2="15" />
                            <line x1="9" y1="9" x2="15" y2="15" />
                        </svg>
                        Bị từ chối: <strong>{{post.rejectionReason}}</strong>
                        <a href="/posts/{{post._id}}/edit" class="btn btn-secondary btn-sm-resp">✏️ Sửa lại</a>
                    </div>
                    {{/if}}
                </div>
                {{/if}}
            </header>

            {{#if post.thumbnail}}
            <img src="{{post.thumbnail}}" alt="{{post.title}}" class="post-detail-thumbnail">
            {{/if}}

            <!-- Mục lục (render bởi JS) -->
            <div class="toc-mobile" id="tocMobile">
                <button class="toc-mobile-toggle" id="tocMobileToggle" aria-expanded="false">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="8" y1="6" x2="21" y2="6" />
                        <line x1="8" y1="12" x2="21" y2="12" />
                        <line x1="8" y1="18" x2="21" y2="18" />
                        <line x1="3" y1="6" x2="3.01" y2="6" />
                        <line x1="3" y1="12" x2="3.01" y2="12" />
                        <line x1="3" y1="18" x2="3.01" y2="18" />
                    </svg>
                    Mục lục
                    <svg class="toc-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="2.5">
                        <path d="m6 9 6 6 6-6" />
                    </svg>
                </button>
                <nav class="toc-mobile-content" id="tocMobileContent" aria-hidden="true"></nav>
            </div>

            <div class="post-detail-content" id="postContent">
                {{{post.content}}}
            </div>

            {{#if post.tags.length}}
            <div class="post-tags">
                {{#each post.tags}}
                <a href="/posts?tag={{this}}" class="tag-badge">#{{this}}</a>
                {{/each}}
            </div>
            {{/if}}
        </article>

        <!-- Sidebar: Mục lục desktop -->
        <aside class="post-sidebar" id="postSidebar">
            <div class="toc-widget" id="tocWidget">
                <h3 class="toc-title">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="8" y1="6" x2="21" y2="6" />
                        <line x1="8" y1="12" x2="21" y2="12" />
                        <line x1="8" y1="18" x2="21" y2="18" />
                        <line x1="3" y1="6" x2="3.01" y2="6" />
                        <line x1="3" y1="12" x2="3.01" y2="12" />
                        <line x1="3" y1="18" x2="3.01" y2="18" />
                    </svg>
                    Mục lục
                </h3>
                <nav class="toc-nav" id="tocNav" aria-label="Mục lục bài viết"></nav>
            </div>
        </aside>

    </div>
</div>
<script src="/js/toc.js"></script>