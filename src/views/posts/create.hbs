<div class="page-container">
    <div class="post-form-wrap">
        <h1 class="page-title">✍️ Viết bài mới</h1>
        {{> flash-message}}
        <form action="/posts/create" method="POST" enctype="multipart/form-data" class="post-form" id="postForm">
            <div class="form-group">
                <label class="form-label">Tiêu đề <span class="required">*</span></label>
                <input type="text" name="title" required maxlength="200" id="post-title" class="form-input"
                    placeholder="Nhập tiêu đề bài đăng...">
            </div>

            <div class="form-row-2">
                <div class="form-group">
                    <label class="form-label">Danh mục</label>
                    <select name="category" class="form-select">
                        <option value="">-- Chọn danh mục --</option>
                        {{#each categories}}
                        <option value="{{_id}}">{{name}}</option>
                        {{/each}}
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Tags <span class="hint">(cách nhau bằng dấu phẩy)</span></label>
                    <input type="text" name="tags" class="form-input" placeholder="ví dụ: công nghệ, AI, lập trình"
                        required>
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">Ảnh bìa (thumbnail)</label>
                <input type="file" name="thumbnail" accept="image/*" class="form-file" id="thumbnailInput" required>
                <div class="img-preview" id="thumbnailPreview"></div>
            </div>

            <div class="form-group">
                <label class="form-label">Nội dung <span class="required">*</span></label>
                <div id="editor" class="editor-container"></div>
                <textarea name="content" id="contentInput" style="display:none"></textarea>
            </div>

            <div class="form-group">
                <label class="form-label">Thêm ảnh vào nội dung</label>
                <input type="file" name="contentImages" accept="image/*" multiple class="form-file">
                <p class="hint">Tối đa 10 ảnh, mỗi ảnh tối đa 5MB</p>
            </div>

            <div class="form-submit">
                <button type="submit" name="action" value="draft" class="btn btn-secondary">💾 Lưu nháp</button>
                <button type="submit" name="action" value="submit" class="btn btn-primary mx-4">📤 Gửi duyệt</button>
            </div>
        </form>
    </div>
</div>
<script src="/js/editor.js"></script>