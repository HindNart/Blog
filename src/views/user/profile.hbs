<div class="page-container profile-page">
    <div class="profile-layout">

        <!-- ── Cột trái: Avatar + thống kê ── -->
        <aside class="profile-sidebar">
            <div class="profile-card">

                <!-- Avatar -->
                <div class="avatar-section">
                    <div class="avatar-wrapper" id="avatarWrapper">
                        {{#if user.avatar}}
                        <img src="{{user.avatar}}" alt="Avatar" class="profile-avatar" id="avatarImg">
                        {{else}}
                        <div class="profile-avatar-placeholder" id="avatarPlaceholder">
                            {{substr user.username 0 1}}
                        </div>
                        {{/if}}
                        <button class="avatar-edit-btn" id="avatarEditBtn" title="Đổi avatar">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2.5">
                                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                            </svg>
                        </button>
                    </div>

                    <!-- Upload input ẩn -->
                    <input type="file" id="avatarFileInput" accept="image/jpeg,image/png,image/webp"
                        style="display:none" aria-hidden="true">

                    <!-- Nút xóa avatar (chỉ hiện khi có avatar) -->
                    {{#if user.avatar}}
                    <button class="btn-remove-avatar" id="removeAvatarBtn" title="Xóa avatar">
                        Xóa ảnh mặc định
                    </button>
                    {{/if}}

                    <div id="avatarMsg" class="avatar-msg" role="status" aria-live="polite"></div>
                </div>

                <!-- Thông tin user -->
                <div class="profile-info">
                    <h2 class="profile-username">{{user.username}}</h2>
                    <p class="profile-email">{{user.email}}</p>
                    <div class="profile-badges">
                        {{#if user.isEmailVerified}}
                        <span class="badge badge-success">✅ Email đã xác minh</span>
                        {{else}}
                        <span class="badge badge-warning">⚠️ Chưa xác minh email</span>
                        {{/if}}
                        {{#if (eq user.role 'admin')}}
                        <span class="badge badge-danger">⚡ Admin</span>
                        {{/if}}
                    </div>
                    <p class="profile-joined">
                        Tham gia: {{formatDate user.createdAt}}
                    </p>
                </div>

                <!-- Thống kê -->
                <div class="profile-stats">
                    <div class="stat-item">
                        <span class="stat-n">{{stats.totalPosts}}</span>
                        <span class="stat-l">Tổng bài</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-n stat-green">{{stats.approvedPosts}}</span>
                        <span class="stat-l">Đã duyệt</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-n stat-yellow">{{stats.pendingPosts}}</span>
                        <span class="stat-l">Chờ duyệt</span>
                    </div>
                </div>
            </div>
        </aside>

        <!-- ── Cột phải: Cài đặt tài khoản ── -->
        <div class="profile-main">

            <!-- Đổi mật khẩu -->
            <section class="settings-section">
                <div class="auth-logo">🔐</div>
                <h1 class="auth-title">Đổi mật khẩu</h1>
                {{> flash-message}}
                <form action="/auth/change-password?_method=PATCH" method="POST" class="auth-form" id="changePwdForm"
                    novalidate>
                    <div class="form-group">
                        <label class="form-label" for="cur-pwd">Mật khẩu hiện tại</label>
                        <div class="input-wrapper">
                            <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2">
                                <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                                <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                            </svg>
                            <input type="password" id="cur-pwd" name="currentPassword" required
                                class="form-input input-with-icon" autocomplete="current-password">
                            <button type="button" class="pwd-toggle" data-target="cur-pwd" aria-label="Hiện/ẩn"><svg
                                    class="eye-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                    stroke-width="2">
                                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                                    <circle cx="12" cy="12" r="3" />
                                </svg></button>
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label" for="new-pwd">Mật khẩu mới</label>
                        <div class="input-wrapper">
                            <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2">
                                <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                                <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                            </svg>
                            <input type="password" id="new-pwd" name="newPassword" required minlength="8"
                                class="form-input input-with-icon" autocomplete="new-password">
                            <button type="button" class="pwd-toggle" data-target="new-pwd" aria-label="Hiện/ẩn"><svg
                                    class="eye-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                    stroke-width="2">
                                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                                    <circle cx="12" cy="12" r="3" />
                                </svg></button>
                        </div>
                        <div class="pwd-strength">
                            <div class="pwd-strength-bar">
                                <div class="pwd-strength-fill" id="pwdStrengthFill"></div>
                            </div><span class="pwd-strength-label" id="pwdStrengthLabel"></span>
                        </div>
                        <p class="field-error" id="err-newpwd" role="alert"></p>
                    </div>
                    <div class="form-group">
                        <label class="form-label" for="confirm-pwd">Xác nhận mật khẩu mới</label>
                        <div class="input-wrapper">
                            <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2">
                                <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                                <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                            </svg>
                            <input type="password" id="confirm-pwd" name="confirmPassword" required
                                class="form-input input-with-icon" autocomplete="new-password">
                            <button type="button" class="pwd-toggle" data-target="confirm-pwd" aria-label="Hiện/ẩn"><svg
                                    class="eye-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                    stroke-width="2">
                                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                                    <circle cx="12" cy="12" r="3" />
                                </svg></button>
                        </div>
                        <p class="field-error" id="err-confirm" role="alert"></p>
                    </div>
                    <button type="submit" class="btn btn-primary btn-full">🔐 Đổi mật khẩu</button>
                </form>
            </section>

            <!-- Vùng nguy hiểm: Xóa tài khoản -->
            <section class="settings-section danger-section">
                <h3 class="settings-title danger-title">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10" />
                        <line x1="12" y1="8" x2="12" y2="12" />
                        <line x1="12" y1="16" x2="12.01" y2="16" />
                    </svg>
                    Vùng nguy hiểm
                </h3>
                <div class="danger-body">
                    <div class="danger-info">
                        <p class="danger-title-sm">Xóa tài khoản</p>
                        <p class="danger-desc">
                            Hành động này <strong>không thể hoàn tác</strong>. Tất cả bài đăng của bạn sẽ bị ẩn khỏi
                            trang web. Dữ liệu tài khoản sẽ bị xóa vĩnh viễn.
                        </p>
                    </div>
                    <button class="btn btn-danger" id="openDeleteModalBtn">🗑️ Xóa tài khoản</button>
                </div>
            </section>
        </div>
    </div>
</div>

<!-- ── Modal xác nhận xóa tài khoản ── -->
<div class="modal-overlay" id="deleteAccountModal" style="display:none" role="dialog" aria-modal="true"
    aria-labelledby="deleteModalTitle">
    <div class="modal delete-modal">
        <div class="delete-modal-header">
            <div class="delete-modal-icon">⚠️</div>
            <h3 id="deleteModalTitle">Xác nhận xóa tài khoản</h3>
            <p>Vui lòng nhập mật khẩu để xác nhận. Hành động này <strong>không thể hoàn tác</strong>.</p>
        </div>

        <div class="form-group">
            <label class="form-label" for="delete-pwd">Mật khẩu xác nhận</label>
            <div class="input-wrapper">
                <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="11" width="18" height="11" rx="2" />
                    <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                </svg>
                <input type="password" id="delete-pwd" class="form-input input-with-icon"
                    placeholder="Nhập mật khẩu của bạn" autocomplete="current-password">
                <button type="button" class="pwd-toggle" data-target="delete-pwd" aria-label="Hiện/ẩn">
                    <svg class="eye-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                        <circle cx="12" cy="12" r="3" />
                    </svg>
                </button>
            </div>
            <p class="field-error" id="err-delete-pwd"></p>
        </div>

        <div id="deleteMsg" class="form-msg form-msg-error" role="alert" aria-live="polite"></div>

        <div class="modal-actions">
            <button type="button" class="btn btn-secondary" id="cancelDeleteBtn">Hủy bỏ</button>
            <button type="button" class="btn btn-danger" id="confirmDeleteBtn">
                <span class="btn-text">🗑️ Xóa vĩnh viễn</span>
                <span class="btn-loading" style="display:none">⏳ Đang xử lý...</span>
            </button>
        </div>
    </div>
</div>

<script src="/js/profile.js"></script>