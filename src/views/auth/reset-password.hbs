<div class="auth-container">
    <div class="auth-card">
        <div class="auth-logo">🔒</div>
        <h1 class="auth-title">Đặt lại mật khẩu</h1>
        {{> flash-message}}
        <form action="/auth/reset-password?_method=PUT" method="POST" class="auth-form" id="resetForm" novalidate>
            <input type="hidden" name="token" value="{{token}}">
            <div class="form-group">
                <label class="form-label" for="reset-pwd">Mật khẩu mới</label>
                <div class="input-wrapper">
                    <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                        <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                    </svg>
                    <input type="password" id="reset-pwd" name="password" required minlength="8"
                        class="form-input input-with-icon" placeholder="Tối thiểu 8 ký tự" autocomplete="new-password">
                    <button type="button" class="pwd-toggle" data-target="reset-pwd" aria-label="Hiện/ẩn">
                        <svg class="eye-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                            <circle cx="12" cy="12" r="3" />
                        </svg>
                    </button>
                </div>
                <div class="pwd-strength">
                    <div class="pwd-strength-bar">
                        <div class="pwd-strength-fill" id="pwdStrengthFill"></div>
                    </div><span class="pwd-strength-label" id="pwdStrengthLabel"></span>
                </div>
                <p class="field-error" id="err-password" role="alert"></p>
            </div>
            <div class="form-group">
                <label class="form-label" for="reset-confirm">Xác nhận mật khẩu</label>
                <div class="input-wrapper">
                    <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                        <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                    </svg>
                    <input type="password" id="reset-confirm" name="confirmPassword" required
                        class="form-input input-with-icon" placeholder="Nhập lại mật khẩu" autocomplete="new-password">
                    <button type="button" class="pwd-toggle" data-target="reset-confirm" aria-label="Hiện/ẩn">
                        <svg class="eye-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                            <circle cx="12" cy="12" r="3" />
                        </svg>
                    </button>
                </div>
                <p class="field-error" id="err-confirm" role="alert"></p>
            </div>
            <button type="submit" class="btn btn-primary btn-full">Đặt lại mật khẩu</button>
        </form>
    </div>
</div>