<div class="auth-container">
    <div class="auth-card">
        <div class="auth-logo">✍️</div>
        <h1 class="auth-title">Tạo tài khoản</h1>
        <p class="auth-subtitle">Tham gia cộng đồng Blog App ngay hôm nay</p>
        {{> flash-message}}

        <form action="/auth/register" method="POST" class="auth-form" id="registerForm" novalidate>
            <div class="form-group">
                <label class="form-label" for="reg-username">Tên người dùng</label>
                <div class="input-wrapper">
                    <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                        <circle cx="12" cy="7" r="4" />
                    </svg>
                    <input type="text" id="reg-username" name="username" value="{{username}}"
                        class="form-input input-with-icon" placeholder="vd: john_doe123" minlength="3" maxlength="30"
                        autocomplete="username">
                </div>
                <p class="field-hint">3–30 ký tự, chỉ chữ cái, số và dấu gạch dưới</p>
                <p class="field-error" id="err-username" role="alert"></p>
            </div>

            <div class="form-group">
                <label class="form-label" for="reg-email">Email</label>
                <div class="input-wrapper">
                    <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                        <polyline points="22,6 12,13 2,6" />
                    </svg>
                    <input type="email" id="reg-email" name="email" value="{{email}}" class="form-input input-with-icon"
                        placeholder="email@example.com" autocomplete="email">
                </div>
                <p class="field-error" id="err-email" role="alert"></p>
            </div>

            <div class="form-group">
                <label class="form-label" for="reg-password">Mật khẩu</label>
                <div class="input-wrapper">
                    <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                        <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                    </svg>
                    <input type="password" id="reg-password" name="password" class="form-input input-with-icon"
                        placeholder="Tối thiểu 8 ký tự" autocomplete="new-password">
                    <button type="button" class="pwd-toggle" data-target="reg-password" aria-label="Hiện/ẩn mật khẩu">
                        <svg class="eye-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                            <circle cx="12" cy="12" r="3" />
                        </svg>
                    </button>
                </div>
                <!-- Thanh độ mạnh mật khẩu -->
                <div class="pwd-strength" id="pwdStrength">
                    <div class="pwd-strength-bar">
                        <div class="pwd-strength-fill" id="pwdStrengthFill"></div>
                    </div>
                    <span class="pwd-strength-label" id="pwdStrengthLabel"></span>
                </div>
                <p class="field-error" id="err-password" role="alert"></p>
            </div>

            <div class="form-group">
                <label class="form-label" for="reg-confirm">Xác nhận mật khẩu</label>
                <div class="input-wrapper">
                    <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                        <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                    </svg>
                    <input type="password" id="reg-confirm" name="confirmPassword" class="form-input input-with-icon"
                        placeholder="Nhập lại mật khẩu" autocomplete="new-password">
                    <button type="button" class="pwd-toggle" data-target="reg-confirm" aria-label="Hiện/ẩn mật khẩu">
                        <svg class="eye-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                            <circle cx="12" cy="12" r="3" />
                        </svg>
                    </button>
                </div>
                <p class="field-error" id="err-confirm" role="alert"></p>
            </div>

            <button type="submit" class="btn btn-primary btn-full" id="registerBtn">
                <span class="btn-text">Tạo tài khoản</span>
                <span class="btn-loading" style="display:none">⏳ Đang xử lý...</span>
            </button>
        </form>
        <p class="auth-switch">Đã có tài khoản? <a href="/auth/login">Đăng nhập</a></p>
    </div>
</div>