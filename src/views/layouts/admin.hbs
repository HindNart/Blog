<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}} | Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
        crossorigin="anonymous"></script>
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <link rel="stylesheet" href="/css/main.css">
    <link rel="stylesheet" href="/css/admin.css">
</head>

<body>
    <div class="admin-layout">
        <aside class="admin-sidebar">
            <div class="sidebar-brand">Admin Panel</div>
            <nav class="sidebar-nav">
                <a href="/admin/dashboard"
                    class="sidebar-link {{#if (eq title 'Dashboard Admin')}}active{{/if}}">Dashboard</a>
                <a href="/admin/posts" class="sidebar-link {{#if (eq title 'Tất cả bài đăng')}}active{{/if}}">Tất cả
                    bài</a>
                <a href="/admin/posts/pending"
                    class="sidebar-link {{#if (eq title 'Bài đăng chờ duyệt')}}active{{/if}}">Chờ duyệt</a>
                <a href="/admin/posts/deleted" class="sidebar-link {{#if (eq title 'Bài đăng đã xóa')}}active{{/if}}">Đã
                    xóa</a>
                <hr>
                <a href="/posts" class="sidebar-link">Xem trang web</a>
                <form action="/auth/logout" method="POST" style="margin:0">
                    <button type="submit" class="sidebar-link sidebar-logout">Đăng xuất</button>
                </form>
            </nav>
        </aside>
        <div class="admin-main">
            <header class="admin-topbar">
                <h1 class="admin-page-title">{{title}}</h1>
                <span class="admin-user">{{currentUser.userId}}</span>
            </header>
            <div class="admin-content">
                {{> flash-message}}
                {{{body}}}
            </div>
        </div>
    </div>

    <script src="/js/main.js"></script>
    <script src="/js/admin.js"></script>
</body>

</html>